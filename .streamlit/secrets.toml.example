# Streamlit secrets template.
#
# For local dev: copy this file to .streamlit/secrets.toml and fill in real keys,
# OR just use a .env file at the project root (either works).
#
# For Streamlit Community Cloud: paste this content (with real keys) into the
# "Secrets" panel under your app's settings. The file itself does not need to
# be committed to the cloud.

ANTHROPIC_API_KEY = "sk-ant-..."
PERPLEXITY_API_KEY = "pplx-..."

# When DEMO_MODE is true, the "Run agent" button is disabled so public visitors
# cannot burn your API credits. Set to false locally when you want to add leads.
DEMO_MODE = true
